# Site Configuration
NEXT_PUBLIC_SITE_NAME=Your Site Name
NEXT_PUBLIC_TAGLINE=Your tagline here
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Social Media
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_handle

# Contact Info
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
NEXT_PUBLIC_LOCATION=Johannesburg, South Africa

# EmailJS (sign up at https://www.emailjs.com/)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# Optional anti-bot challenge (Cloudflare Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key_if_needed
